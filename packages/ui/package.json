{
  "name": "ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "test": "vitest run --config ../../vitest.config.ts src",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "next": "^15.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "next": "^15.0.0",
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "@tailwindcss/forms": "^0.5.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "config-tailwind": "workspace:*",
    "lucide-react": "^0.546.0",
    "shared": "workspace:*",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.15",
    "tw-animate-css": "^1.4.0"
  }
}
